  m_Name: 
  m_EditorClassIdentifier: Unity.TextMeshPro::TMPro.TextMeshProUGUI
  m_Material: {fileID: 0}
  m_Color: {r: 1, g: 1, b: 1, a: 1}
  m_RaycastTarget: 1
  m_RaycastPadding: {x: 0, y: 0, z: 0, w: 0}
  m_Maskable: 1
  m_OnCullStateChanged:
    m_PersistentCalls:
      m_Calls: []
  m_text: "This showcases Uli (or Uri) motifs, a traditional aesthetic practiced
    primarily by the Igbo people.\n\nOrigins in Body and Mural Art: Uli was traditionally
    a female-led art form where designs were painted onto the body for festivals
    or onto the walls of shrines and homes using natural dyes.\n\nBold Minimalism:
    Unlike many other decorative traditions, Uli is famous for its minimalist use
    of space and bold, fluid lines. It relies on \"positive\" and \"negative\" space
    to create balance.\n\nSymbolic Language: Each motif has a specific meaning, often
    drawn from nature or daily objects. For example:\n\nEke/Onwa: Representing the
    python or the moon.\n\nAnimal Prints: Like the \"Leopard\u2019s paw print\" or
    \"Tortoise\" (symbolizing wisdom and trickery).\n\nObjects: Such as the Ogene
    (gong) or Isioji (kola nut).\n\nModern Influence: In the mid-20th century, the
    \"Nsukka School\" of artists modernized Uli, moving it from the skin and walls
    onto canvas, influencing contemporary Nigerian art and design."
  m_isRightToLeft: 0
  m_fontAsset: {fileID: 11400000, guid: 8f586378b4e144a9851e7b34d9b748ee, type: 2}
  m_sharedMaterial: {fileID: 2180264, guid: 8f586378b4e144a9851e7b34d9b748ee, type: 2}
